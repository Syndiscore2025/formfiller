generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  applications Application[]
  settings     TenantSettings?
  chatMessages ChatMessage[]

  @@index([slug])
  @@index([apiKey])
}

/// Per-tenant configuration: branding, CRM integration, and completion behaviour.
model TenantSettings {
  id                  String   @id @default(uuid())
  tenantId            String   @unique

  // ── Branding (UI + PDF) ──────────────────────────────────────────────────
  companyName         String?  /// Display name shown in PDF header and form UI
  legalBusinessName   String?  /// Legal entity name shown in PDF footer
  logoUrl             String?  /// Public URL of the tenant logo (embedded in PDF + form header)
  companyEmail        String?  /// Contact email shown in PDF footer
  companyPhone        String?  /// Contact phone shown in PDF footer
  companyAddress      String?  /// Mailing address shown in PDF footer

  // ── UI Theme (white-label embed) ─────────────────────────────────────────
  theme               String?  @default("dark") /// 'dark' | 'light' — applied to merchant form + admin
  accentColor         String?  /// Hex color replacing the default cyan accent (#22d3ee)
  surfaceColor        String?  /// Hex color for panel/card backgrounds (default: #0f172a)

  // ── PDF privacy toggles ──────────────────────────────────────────────────
  // Brokers re-sending signed apps to lenders via API may want to redact
  // sensitive merchant contact and funding data. All default true.
  pdfShowContactEmail     Boolean @default(true)  /// Include merchant contact email on PDF
  pdfShowContactPhone     Boolean @default(true)  /// Include merchant contact phone on PDF
  pdfShowAnnualRevenue    Boolean @default(true)  /// Include estimated annual revenue on PDF
  pdfShowAmountRequested  Boolean @default(true)  /// Include amount requested on PDF
  showEstimatedCreditScore Boolean @default(true) /// Show estimated credit score on merchant app, PDF, and delivery payload

  // ── Post-completion ──────────────────────────────────────────────────────
  websiteUrl          String?  /// Where the merchant is redirected after completing the application
  supportEmail        String?  /// Shown on the completion screen as a contact fallback

  // ── Switchbox CRM integration ────────────────────────────────────────────
  switchboxApiUrl     String?  /// POST endpoint Switchbox provides for receiving applications
  switchboxApiKey     String?  /// Bearer token / API key (stored encrypted in application)

  // ── Document storage ─────────────────────────────────────────────────────
  documentStorageProvider        String? @default("database") /// database | s3
  documentStorageEndpoint        String? /// S3-compatible endpoint (DigitalOcean Spaces/AWS S3)
  documentStorageRegion          String? /// S3 region, e.g. nyc3 or us-east-1
  documentStorageBucket          String? /// Private bucket for signed PDFs and bank statements
  documentStoragePrefix          String? /// Optional key prefix, e.g. tenants/
  documentStorageAccessKeyId     String? /// S3-compatible access key ID
  documentStorageSecretAccessKey String? /// Encrypted S3-compatible secret access key
  documentStoragePublicBaseUrl   String? /// Optional CDN/base URL for non-sensitive references

  // ── SMTP (outbound email) ─────────────────────────────────────────────────
  smtpHost                    String?  /// SMTP server hostname (e.g. smtp.sendgrid.net)
  smtpPort                    Int?     /// SMTP port — 587 for STARTTLS, 465 for SSL
  smtpSecure                  Boolean  @default(false) /// true = implicit TLS (port 465)
  smtpUser                    String?  /// SMTP authentication username
  smtpPass                    String?  /// SMTP password (stored encrypted)
  smtpFrom                    String?  /// From address (e.g. noreply@example.com)
  smtpFromName                String?  /// Display name in the From header (e.g. Switchbox Funding)

  // ── Email: Abandoned application ──────────────────────────────────────────
  emailAbandonedEnabled       Boolean  @default(false) /// Send follow-up when merchant abandons the form
  emailAbandonedDelayMinutes  Int      @default(1440)  /// Minutes of inactivity before triggering (default 1440 = 24 h)
  emailAbandonedSubject       String?  @default("Complete your funding application")
  emailAbandonedBody          String?  /// Supports {firstName}, {companyName} placeholders
  emailAbandonedIncludeLogo   Boolean  @default(true)
  emailAbandonedIncludeSig    Boolean  @default(true)

  // ── Email: Submitted but no bank statements ───────────────────────────────
  emailNoBanksEnabled         Boolean  @default(false) /// Send follow-up when app finalized with 0 bank statements
  emailNoBanksSubject         String?  @default("Don't forget to upload your bank statements")
  emailNoBanksBody            String?  /// Supports {firstName}, {companyName} placeholders
  emailNoBanksIncludeLogo     Boolean  @default(true)
  emailNoBanksIncludeSig      Boolean  @default(true)

  // ── Email: Submitted with insufficient bank statements ────────────────────
  emailInsufficientBanksEnabled  Boolean  @default(false) /// Send follow-up when app finalized with fewer than minimum statements
  emailMinBankStatements         Int      @default(3)     /// Minimum number of statements required before triggering
  emailInsufficientBanksSubject  String?  @default("We need more bank statements to process your application")
  emailInsufficientBanksBody     String?  /// Supports {firstName}, {companyName}, {uploadedCount}, {requiredCount} placeholders
  emailInsufficientBanksIncludeLogo Boolean @default(true)
  emailInsufficientBanksIncludeSig  Boolean @default(true)

  // ── AI chat agent ───────────────────────────────────────────────────────────
  aiChatEnabled          Boolean @default(true)
  aiPersonaName          String? @default("Funding Assistant")
  aiSystemPromptOverride String?
  aiEligibilityRules     Json?
  aiModel                String?

  // ── Custom tenant frontend / headless API ───────────────────────────────────
  customFrontendEnabled          Boolean @default(false)
  customFrontendPublicKeyHash    String?
  customFrontendKeyPreview       String?
  customFrontendAllowedOrigins   Json?
  customFrontendAllowedRedirects Json?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

/// Tracks each outbound CRM delivery attempt for an application.
model CrmDelivery {
  id                String   @id @default(uuid())
  applicationId     String   @unique   /// One delivery record per application
  status            String   @default("pending")  /// pending | sent | failed | skipped
  attempts          Int      @default(0)
  lastAttemptAt     DateTime?
  nextRetryAt       DateTime?
  sentAt            DateTime?
  externalAccountId String?  /// Account ID returned by the CRM on success
  lastError         String?
  payload           Json?    /// Snapshot of the payload we sent (for debugging)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  role         String   @default("agent")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  applications Application[]
  reportExports ReportExportAudit[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model ReportExportAudit {
  id               String   @id @default(uuid())
  userId           String?
  reportType       String
  includeSensitive Boolean  @default(false)
  startDate        DateTime?
  endDate          DateTime?
  rowCount         Int      @default(0)
  createdAt        DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
}

model Application {
  id                    String    @id @default(uuid())
  tenantId              String
  userId                String?
  status                String    @default("draft")
  currentStep           Int       @default(1)
  completionPct         Int       @default(0)
  ipAddress             String?
  userAgent             String?
  contactFirstName      String?
  contactLastName       String?
  contactEmail          String?
  contactPhone          String?
  tcpaConsentStep1      Boolean   @default(false)
  tcpaConsentStep1At    DateTime?
  hasAdditionalOwners   Boolean?
  homeBasedBusiness     Boolean?
  ownerHomeSameAsBusiness Boolean?
  lastActivityAt        DateTime  @default(now())
  warmLeadSentAt        DateTime?
  abandonedEmailSentAt  DateTime?
  finalizedAt           DateTime?
  disqualifiedAt        DateTime?
  disqualificationReason String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])
  business        BusinessInfo?
  owners          OwnerInfo[]
  financial       FinancialInfo?
  loanRequest     LoanRequest?
  signature       Signature?
  documents       ApplicationDocument[]
  analyticsEvents AnalyticsEvent[]
  auditLogs       AuditLog[]
  crmDelivery     CrmDelivery?
  chatMessages    ChatMessage[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([status, tcpaConsentStep1, warmLeadSentAt, lastActivityAt])
}

model BusinessInfo {
  id                String   @id @default(uuid())
  applicationId     String   @unique
  legalName         String?
  dba               String?
  entityType        String?
  industry          String?
  stateOfFormation  String?
  ein               String?
  businessStartDate DateTime?
  phone             String?
  website           String?
  streetAddress     String?
  streetAddress2    String?
  city              String?
  state             String?
  zipCode           String?
  sicCode           String?
  naicsCode         String?
  autoPopulated     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model OwnerInfo {
  id              String   @id @default(uuid())
  applicationId   String
  ownerIndex      Int      @default(0)
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  ownershipPct    String?  // stored as string (e.g., "51")
  ssnEncrypted    String?
  dateOfBirth     String?  // stored as string (YYYY-MM-DD)
  creditScore     String?
  streetAddress   String?
  streetAddress2  String?
  city            String?
  state           String?
  zipCode         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, ownerIndex])
  @@index([applicationId])
}

model FinancialInfo {
  id                   String   @id @default(uuid())
  applicationId        String   @unique
  annualRevenue        String?  // dropdown range value (e.g., "100k-250k")
  monthlyRevenue       Float?   // deprecated - kept for backwards compatibility
  monthlyExpenses      Float?   // deprecated - kept for backwards compatibility
  outstandingDebts     Float?   // deprecated - kept for backwards compatibility
  bankruptcyHistory    Boolean? // deprecated - kept for backwards compatibility
  bankName             String?  // deprecated - kept for backwards compatibility
  accountType          String?  // deprecated - kept for backwards compatibility
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model LoanRequest {
  id              String   @id @default(uuid())
  applicationId   String   @unique
  amountRequested String?  // dropdown range value (e.g., "50k-100k")
  purpose         String?
  urgency         String?
  termPreference  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Signature {
  id                        String    @id @default(uuid())
  applicationId             String    @unique
  signatureData             String
  signerName                String
  signerEmail               String
  ipAddress                 String
  userAgent                 String
  consentText               String
  signedAt                  DateTime
  marketingConsent          Boolean   @default(false)
  marketingConsentTimestamp DateTime?
  createdAt                 DateTime  @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ApplicationDocument {
  id            String   @id @default(uuid())
  applicationId String
  documentType  String   @default("bank_statement")
  statementMonth String
  fileName      String
  mimeType      String
  sizeBytes     Int
  content       Bytes?
  storageProvider String?
  storageBucket   String?
  storageKey      String?
  storageUrl      String?
  storageEtag     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, documentType, statementMonth])
  @@index([applicationId, documentType])
  @@index([storageProvider])
}

model BankHelpCache {
  id                 String   @id @default(uuid())
  normalizedBankName String   @unique
  bankName           String
  bankUrl            String?
  instructions       String
  sourcePages        String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([bankName])
}

model ChatMessage {
  id            String   @id @default(uuid())
  tenantId      String
  applicationId String
  role          String   /// user | assistant | system
  content       String
  metadata      Json?
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, applicationId, createdAt])
  @@index([applicationId, createdAt])
}

model AnalyticsEvent {
  id            String   @id @default(uuid())
  applicationId String
  fieldName     String?
  eventType     String
  durationMs    Int?
  metadata      Json?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([eventType])
}

model AuditLog {
  id            String   @id @default(uuid())
  applicationId String
  action        String
  actor         String?
  ipAddress     String?
  details       Json?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

