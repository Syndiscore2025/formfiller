            "body": { "mode": "raw", "raw": "{\n  \"hasAdditionalOwners\": {{has_additional_owners}},\n  \"homeBasedBusiness\": {{home_based_business}},\n  \"ownerHomeSameAsBusiness\": {{owner_home_same_as_business}}\n}" },
            "url": "{{backend_base_url}}/api/applications/{{application_id}}"
