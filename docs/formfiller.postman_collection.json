{
  "info": {
    "name": "Form Filler API - Switchbox Handoff",
    "description": "Complete endpoint collection matching all real API routes. Uses placeholders only; set real secrets in local/current Postman values or Switchbox password manager, never in source control. Live DigitalOcean URLs (backend: https://formfiller-backend-wtxtc.ondigitalocean.app, frontend: https://formfiller-frontend-uasuj.ondigitalocean.app) are provided as variables below — set backend_base_url to backend_base_url_do (or select the environment file) to run against production.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "noauth" },
  "variable": [
    { "key": "backend_base_url", "value": "http://localhost:4000" },
    { "key": "backend_base_url_do", "value": "https://formfiller-backend-wtxtc.ondigitalocean.app" },
    { "key": "frontend_base_url", "value": "http://localhost:3002" },
    { "key": "frontend_base_url_do", "value": "https://formfiller-frontend-uasuj.ondigitalocean.app" },
    { "key": "tenant_slug", "value": "default" },
    { "key": "admin_email", "value": "admin@example.com" },
    { "key": "admin_password", "value": "REPLACE_LOCALLY_DO_NOT_COMMIT" },
    { "key": "application_id", "value": "PASTE_CREATED_APPLICATION_ID" },
    { "key": "place_id", "value": "PASTE_GOOGLE_PLACE_ID" },
    { "key": "auth_token", "value": "PASTE_JWT_LOCALLY_DO_NOT_COMMIT" },
    { "key": "switchbox_api_url", "value": "https://switchbox.example.com/webhook" },
    { "key": "switchbox_api_key", "value": "REPLACE_LOCALLY_DO_NOT_COMMIT" },
    { "key": "document_storage_provider", "value": "database" },
    { "key": "document_storage_endpoint", "value": "" },
    { "key": "document_storage_region", "value": "" },
    { "key": "document_storage_bucket", "value": "" },
    { "key": "document_storage_prefix", "value": "" },
    { "key": "document_storage_access_key_id", "value": "" },
    { "key": "document_storage_secret_access_key", "value": "REPLACE_LOCALLY_DO_NOT_COMMIT" },
    { "key": "document_storage_public_base_url", "value": "" },
    { "key": "smtp_host", "value": "" },
    { "key": "smtp_user", "value": "" },
    { "key": "smtp_pass", "value": "REPLACE_LOCALLY_DO_NOT_COMMIT" },
    { "key": "smtp_from", "value": "support@example.com" },
    { "key": "smtp_from_name", "value": "Switchbox Funding" },
    { "key": "sample_base64_pdf", "value": "data:application/pdf;base64,REPLACE_WITH_BASE64_PDF" },
    { "key": "sample_signature_png", "value": "data:image/png;base64,REPLACE_WITH_BASE64_SIGNATURE" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": "{{backend_base_url}}/health" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\",\n  \"tenantSlug\": \"{{tenant_slug}}\",\n  \"tenantName\": \"Switchbox Demo Tenant\"\n}"
            },
            "url": "{{backend_base_url}}/api/auth/register"
          }
        },
        {
          "name": "POST /api/auth/login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) pm.environment.set('auth_token', json.token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\",\n  \"tenantSlug\": \"{{tenant_slug}}\"\n}"
            },
            "url": "{{backend_base_url}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Tenant Settings",
      "item": [
        {
          "name": "GET /api/tenant/settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-tenant-slug", "value": "{{tenant_slug}}" }],
            "url": "{{backend_base_url}}/api/tenant/settings"
          }
        },
        {
          "name": "GET /api/tenant/settings/admin",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "url": "{{backend_base_url}}/api/tenant/settings/admin"
          }
        },
        {
          "name": "PATCH /api/tenant/settings/admin",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Switchbox Funding\",\n  \"legalBusinessName\": \"Switchbox LLC\",\n  \"logoUrl\": null,\n  \"companyEmail\": \"support@example.com\",\n  \"companyPhone\": \"8602026706\",\n  \"companyAddress\": \"123 Main St, Hartford, CT 06103\",\n  \"websiteUrl\": \"https://example.com\",\n  \"supportEmail\": \"support@example.com\",\n  \"theme\": \"dark\",\n  \"accentColor\": \"#0284c7\",\n  \"surfaceColor\": \"#ffffff\",\n  \"pdfShowContactEmail\": true,\n  \"pdfShowContactPhone\": true,\n  \"pdfShowAnnualRevenue\": true,\n  \"pdfShowAmountRequested\": true,\n  \"switchboxApiUrl\": \"{{switchbox_api_url}}\",\n  \"switchboxApiKey\": \"{{switchbox_api_key}}\",\n  \"documentStorageProvider\": \"{{document_storage_provider}}\",\n  \"documentStorageEndpoint\": \"{{document_storage_endpoint}}\",\n  \"documentStorageRegion\": \"{{document_storage_region}}\",\n  \"documentStorageBucket\": \"{{document_storage_bucket}}\",\n  \"documentStoragePrefix\": \"{{document_storage_prefix}}\",\n  \"documentStorageAccessKeyId\": \"{{document_storage_access_key_id}}\",\n  \"documentStorageSecretAccessKey\": \"{{document_storage_secret_access_key}}\",\n  \"documentStoragePublicBaseUrl\": \"{{document_storage_public_base_url}}\",\n  \"smtpHost\": \"{{smtp_host}}\",\n  \"smtpPort\": 587,\n  \"smtpSecure\": false,\n  \"smtpUser\": \"{{smtp_user}}\",\n  \"smtpPass\": \"{{smtp_pass}}\",\n  \"smtpFrom\": \"{{smtp_from}}\",\n  \"smtpFromName\": \"{{smtp_from_name}}\",\n  \"emailAbandonedEnabled\": true,\n  \"emailAbandonedDelayMinutes\": 1440,\n  \"emailAbandonedSubject\": \"Complete your funding application\",\n  \"emailAbandonedBody\": \"Hi {firstName},\\n\\nYou started a funding application but haven't finished it yet. We'd love to help you get funded.\\n\\nClick here to complete your application: {applicationUrl}\\n\\nIf you have any questions, reply to this email.\",\n  \"emailAbandonedIncludeLogo\": true,\n  \"emailAbandonedIncludeSig\": true,\n  \"emailNoBanksEnabled\": true,\n  \"emailNoBanksSubject\": \"Don't forget to upload your bank statements\",\n  \"emailNoBanksBody\": \"Hi {firstName},\\n\\nYour application has been received but we still need your bank statements to proceed.\\n\\nPlease upload them here: {applicationUrl}\",\n  \"emailNoBanksIncludeLogo\": true,\n  \"emailNoBanksIncludeSig\": true,\n  \"emailInsufficientBanksEnabled\": true,\n  \"emailMinBankStatements\": 3,\n  \"emailInsufficientBanksSubject\": \"We need more bank statements to process your application\",\n  \"emailInsufficientBanksBody\": \"Hi {firstName},\\n\\nWe received your application but only have {uploadedCount} of the {requiredCount} required bank statements. Please upload the remaining statements here: {applicationUrl}\",\n  \"emailInsufficientBanksIncludeLogo\": true,\n  \"emailInsufficientBanksIncludeSig\": true,\n  \"aiChatEnabled\": true,\n  \"aiPersonaName\": \"Funding Assistant\",\n  \"aiSystemPromptOverride\": null,\n  \"aiModel\": \"gpt-4o\"\n}"
            },
            "url": "{{backend_base_url}}/api/tenant/settings/admin"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "GET /api/applications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "url": "{{backend_base_url}}/api/applications"
          }
        },
        {
          "name": "POST /api/applications",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.data && json.data.id) pm.environment.set('application_id', json.data.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contactFirstName\": \"Test\",\n  \"contactLastName\": \"Merchant\",\n  \"contactEmail\": \"merchant@example.com\",\n  \"contactPhone\": \"8602026706\",\n  \"tcpaConsent\": true\n}"
            },
            "url": "{{backend_base_url}}/api/applications"
          }
        },
        {
          "name": "GET /api/applications/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-tenant-slug", "value": "{{tenant_slug}}" }],
            "url": "{{backend_base_url}}/api/applications/{{application_id}}"
          }
        },
        {
          "name": "PATCH /api/applications/:id/step",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": { "mode": "raw", "raw": "{ \"currentStep\": 2 }" },
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/step"
          }
        },
        {
          "name": "PATCH /api/applications/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"hasAdditionalOwners\": false,\n  \"homeBasedBusiness\": false,\n  \"ownerHomeSameAsBusiness\": false\n}" },
            "url": "{{backend_base_url}}/api/applications/{{application_id}}"
          }
        },
        {
          "name": "GET /api/applications/:id/documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-tenant-slug", "value": "{{tenant_slug}}" }],
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/documents"
          }
        },
        {
          "name": "POST /api/applications/:id/documents",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"statementMonth\": \"2026-04\",\n  \"fileName\": \"april-bank-statement.pdf\",\n  \"mimeType\": \"application/pdf\",\n  \"fileData\": \"{{sample_base64_pdf}}\"\n}"
            },
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/documents"
          }
        },
        {
          "name": "POST /api/applications/:id/bank-help",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bankName\": \"Chase\",\n  \"bankUrl\": \"https://www.chase.com\"\n}"
            },
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/bank-help"
          }
        },
        {
          "name": "POST /api/applications/:id/submit",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-tenant-slug", "value": "{{tenant_slug}}" }],
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/submit"
          }
        },
        {
          "name": "POST /api/applications/:id/finalize",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-tenant-slug", "value": "{{tenant_slug}}" }],
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/finalize"
          }
        },
        {
          "name": "GET /api/applications/:id/pdf",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-tenant-slug", "value": "{{tenant_slug}}" }],
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/pdf"
          }
        }
      ]
    },
