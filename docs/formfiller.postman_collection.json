  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": "{{backend_base_url}}/health" }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\",\n  \"tenantSlug\": \"{{tenant_slug}}\",\n  \"tenantName\": \"{{tenant_name}}\"\n}"
            },
            "url": "{{backend_base_url}}/api/auth/register"
          }
        },
        {
          "name": "POST /api/auth/login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) pm.environment.set('auth_token', json.token);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\",\n  \"tenantSlug\": \"{{tenant_slug}}\"\n}"
            },
            "url": "{{backend_base_url}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Tenant Settings",
      "item": [
        {
          "name": "GET /api/tenant/settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-tenant-slug", "value": "{{tenant_slug}}" }],
            "url": "{{backend_base_url}}/api/tenant/settings"
          }
        },
        {
          "name": "GET /api/tenant/settings/admin",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "url": "{{backend_base_url}}/api/tenant/settings/admin"
          }
        },
        {
          "name": "PATCH /api/tenant/settings/admin",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"{{tenant_name}}\",\n  \"legalBusinessName\": \"{{tenant_name}}\",\n  \"logoUrl\": null,\n  \"companyEmail\": \"{{smtp_from}}\",\n  \"companyPhone\": \"{{business_phone}}\",\n  \"companyAddress\": \"{{business_street_address}}, {{business_city}}, {{business_state}} {{business_zip}}\",\n  \"websiteUrl\": \"{{business_website}}\",\n  \"supportEmail\": \"{{smtp_from}}\",\n  \"theme\": \"dark\",\n  \"accentColor\": \"#0284c7\",\n  \"surfaceColor\": \"#ffffff\",\n  \"pdfShowContactEmail\": true,\n  \"pdfShowContactPhone\": true,\n  \"pdfShowAnnualRevenue\": true,\n  \"pdfShowAmountRequested\": true,\n  \"switchboxApiUrl\": \"{{switchbox_api_url}}\",\n  \"switchboxApiKey\": \"{{switchbox_api_key}}\",\n  \"documentStorageProvider\": \"{{document_storage_provider}}\",\n  \"documentStorageEndpoint\": \"{{document_storage_endpoint}}\",\n  \"documentStorageRegion\": \"{{document_storage_region}}\",\n  \"documentStorageBucket\": \"{{document_storage_bucket}}\",\n  \"documentStoragePrefix\": \"{{document_storage_prefix}}\",\n  \"documentStorageAccessKeyId\": \"{{document_storage_access_key_id}}\",\n  \"documentStorageSecretAccessKey\": \"{{document_storage_secret_access_key}}\",\n  \"documentStoragePublicBaseUrl\": \"{{document_storage_public_base_url}}\",\n  \"smtpHost\": \"{{smtp_host}}\",\n  \"smtpPort\": 587,\n  \"smtpSecure\": false,\n  \"smtpUser\": \"{{smtp_user}}\",\n  \"smtpPass\": \"{{smtp_pass}}\",\n  \"smtpFrom\": \"{{smtp_from}}\",\n  \"smtpFromName\": \"{{smtp_from_name}}\",\n  \"emailAbandonedEnabled\": true,\n  \"emailAbandonedDelayMinutes\": 1440,\n  \"emailAbandonedSubject\": \"Complete your funding application\",\n  \"emailAbandonedBody\": \"Hi {firstName},\\n\\nYou started a funding application but haven't finished it yet. Complete it here: {applicationUrl}\",\n  \"emailAbandonedIncludeLogo\": true,\n  \"emailAbandonedIncludeSig\": true,\n  \"emailNoBanksEnabled\": true,\n  \"emailNoBanksSubject\": \"Don't forget to upload your bank statements\",\n  \"emailNoBanksBody\": \"Hi {firstName},\\n\\nYour application has been received but we still need your bank statements. Upload them here: {applicationUrl}\",\n  \"emailNoBanksIncludeLogo\": true,\n  \"emailNoBanksIncludeSig\": true,\n  \"emailInsufficientBanksEnabled\": true,\n  \"emailMinBankStatements\": 3,\n  \"emailInsufficientBanksSubject\": \"We need more bank statements to process your application\",\n  \"emailInsufficientBanksBody\": \"Hi {firstName},\\n\\nWe received {uploadedCount} of the {requiredCount} requested bank statements. Upload more here: {applicationUrl}\",\n  \"emailInsufficientBanksIncludeLogo\": true,\n  \"emailInsufficientBanksIncludeSig\": true,\n  \"aiChatEnabled\": true,\n  \"aiPersonaName\": \"Funding Assistant\",\n  \"aiSystemPromptOverride\": null,\n  \"aiModel\": \"gpt-4o\",\n  \"customFrontendEnabled\": true,\n  \"customFrontendPublicKey\": \"{{custom_frontend_public_key}}\",\n  \"customFrontendAllowedOrigins\": [\"{{custom_frontend_allowed_origin}}\"],\n  \"customFrontendAllowedRedirects\": [\"{{custom_frontend_allowed_redirect_url}}\"]\n}"
            },
            "url": "{{backend_base_url}}/api/tenant/settings/admin"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "GET /api/applications",
