              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-slug", "value": "{{tenant_slug}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"statementMonth\": \"{{statement_month}}\",\n  \"fileName\": \"{{statement_file_name}}\",\n  \"mimeType\": \"application/pdf\",\n  \"fileData\": \"{{sample_base64_pdf}}\"\n}"
            },
            "url": "{{backend_base_url}}/api/applications/{{application_id}}/documents"
          }
        },
        {
